@prefix wlrt: <https://wlrt.dev/ontology#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

wlrt: a owl:Ontology ;
    rdfs:label "WLRT Core Ontology" ;
    rdfs:comment "Core structural concepts of Wave Liquidity Redistribution Theory (WLRT)." .

### Core classes

wlrt:LiquidityEnvironment a owl:Class ;
    rdfs:label "Liquidity Environment" ;
    rdfs:comment "Structured system within which liquidity redistribution occurs and where stability and instability are formed." .

wlrt:Flow a owl:Class ;
    rdfs:label "Flow" ;
    rdfs:comment "Directed passage through a system (transactions, information, execution, physical movement, etc.)." .

wlrt:Constraint a owl:Class ;
    rdfs:label "Constraint" ;
    rdfs:comment "Structural condition that determines which flows and transitions are admissible." .

wlrt:Liquidity a owl:Class ;
    rdfs:label "Liquidity" ;
    rdfs:comment "Structural capacity of a system to sustain the passage of flow through constraints without loss of functional integrity." .

wlrt:Compensation a owl:Class ;
    rdfs:label "Compensation" ;
    rdfs:comment "Intrinsic structural ability of an environment to absorb, redistribute, and neutralize stress generated by liquidity redistribution." .

wlrt:Fragility a owl:Class ;
    rdfs:label "Fragility" ;
    rdfs:comment "Accumulated internal susceptibility of an environment to loss of stability under liquidity redistribution." .

wlrt:Stability a owl:Class ;
    rdfs:label "Stability" ;
    rdfs:comment "Ability of an environment to maintain its functional integrity under liquidity redistribution, structurally defined by the relation S = C - F." .

wlrt:Configuration a owl:Class ;
    rdfs:label "Configuration" ;
    rdfs:comment "Ordered structural state of the system, represented in WLRT by canonical configurations built from extrema (Entry-4, Exit-5)." .

wlrt:ADEConfigurationSystem a owl:Class ;
    rdfs:label "A.D.E. Configuration System" ;
    rdfs:comment "Finite canonical configuration system with admissible Entry-4/Exit-5 configurations and a closed set of transitions." .

wlrt:PhaseTime a owl:Class ;
    rdfs:label "Phase Time" ;
    rdfs:comment "Discrete ordering of structural events and configurations, independent of astronomical time." .

wlrt:LiquidityWave a owl:Class ;
    rdfs:label "Liquidity Wave" ;
    rdfs:comment "Structured spatio-temporal redistribution of liquidity within an environment." .

wlrt:FragilityMetric a owl:Class ;
    rdfs:label "Fragility Metric" ;
    rdfs:comment "Structural metric describing aspects of fragility in WLRT." .

wlrt:LocalFragilityIndex a owl:Class ;
    rdfs:subClassOf wlrt:FragilityMetric ;
    rdfs:label "Local Fragility Index (LFI)" ;
    rdfs:comment "Differential metric characterizing local amplification of infinitesimal perturbations." .

wlrt:LocalStabilityMargin a owl:Class ;
    rdfs:subClassOf wlrt:FragilityMetric ;
    rdfs:label "Local Stability Margin (LSM)" ;
    rdfs:comment "Variational metric measuring remaining distance to the boundary of compensability." .

wlrt:FragilityFieldIndex a owl:Class ;
    rdfs:subClassOf wlrt:FragilityMetric ;
    rdfs:label "Fragility Field Index (FFI)" ;
    rdfs:comment "Topological metric characterizing connectivity of low-margin regions and their propagation potential." .

wlrt:WLRTCanonicalLayer a owl:Class ;
    rdfs:label "WLRT Canonical Layer" ;
    rdfs:comment "Core ontology, laws, configuration system, Phase Time, and multi-environment architecture of WLRT, excluding applied strategies and predictive models." .

wlrt:WLRTCompatibleApplied a owl:Class ;
    rdfs:label "WLRT-compatible Applied Framework" ;
    rdfs:comment "Applied framework that uses WLRT concepts consistently but is not part of the WLRT Canon." .

### Object properties

wlrt:hasFlow a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:Flow ;
    rdfs:label "has flow" ;
    rdfs:comment "Associates an environment with flows that pass through it." .

wlrt:hasConstraint a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:Constraint ;
    rdfs:label "has constraint" ;
    rdfs:comment "Associates an environment with constraints governing admissible flows." .

wlrt:hasLiquidity a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:Liquidity ;
    rdfs:label "has liquidity" ;
    rdfs:comment "Associates an environment with its liquidity configuration." .

wlrt:hasCompensation a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:Compensation ;
    rdfs:label "has compensation" ;
    rdfs:comment "Associates an environment with its compensatory capacity." .

wlrt:hasFragility a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:Fragility ;
    rdfs:label "has fragility" ;
    rdfs:comment "Associates an environment with its fragility." .

wlrt:hasStability a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:Stability ;
    rdfs:label "has stability" ;
    rdfs:comment "Associates an environment with its stability state." .

wlrt:hasConfiguration a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:Configuration ;
    rdfs:label "has configuration" ;
    rdfs:comment "Associates an environment with its current structural configuration." .

wlrt:nextConfiguration a owl:ObjectProperty ;
    rdfs:domain wlrt:Configuration ;
    rdfs:range wlrt:Configuration ;
    rdfs:label "next configuration" ;
    rdfs:comment "Admissible next configuration in the A.D.E. system under Phase Time progression." .

wlrt:hasPhaseTime a owl:ObjectProperty ;
    rdfs:domain wlrt:LiquidityEnvironment ;
    rdfs:range wlrt:PhaseTime ;
    rdfs:label "has phase time" ;
    rdfs:comment "Associates an environment with its structural temporal ordering (Phase Time)." .

wlrt:measuredBy a owl:ObjectProperty ;
    rdfs:domain wlrt:Fragility ;
    rdfs:range wlrt:FragilityMetric ;
    rdfs:label "measured by" ;
    rdfs:comment "Associates fragility with fragility metrics that structurally characterize it." .

wlrt:extendsCanonical a owl:ObjectProperty ;
    rdfs:domain wlrt:WLRTCompatibleApplied ;
    rdfs:range wlrt:WLRTCanonicalLayer ;
    rdfs:label "extends canonical" ;
    rdfs:comment "Indicates that an applied framework extends or uses the WLRT Canonical Layer without modifying it." .

### Key canonical law (as annotation)

wlrt:FirstLaw a owl:NamedIndividual ;
    rdfs:label "WLRT First Law (Stability Law)" ;
    rdfs:comment "Stability S is defined structurally by the relation S = C - F, where C is compensation and F is fragility. Stability is not an independent variable." .

wlrt:SecondLaw a owl:NamedIndividual ;
    rdfs:label "WLRT Second Law (Cyclicity)" ;
    rdfs:comment "Liquidity redistribution in any environment is structurally cyclic and cannot develop as a unidirectional or terminal process. Cyclicity refers to structural state classes, not to price patterns." .
